<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Comunicação com Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Foreground Service (obrigatório para qualquer Foreground Service) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Tipo "health": coleta de dados de sensor para atividade física (Android 14+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />

    <!-- Permissão secundária obrigatória para FGS tipo "health" no Android 10+ (API 29+) -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Notificação persistente do monitoramento (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Projeto220261">

        <!-- Tela inicial: Login via Google -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Tela principal: Hub de navegação -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Tela de monitoramento: controla o Foreground Service -->
        <activity
            android:name=".MonitoramentoActivity"
            android:exported="false" />

        <!-- Tela de ranking: lista usuários por média de atividade -->
        <activity
            android:name=".RankingActivity"
            android:exported="false" />

        <!-- Foreground Service: lê o acelerômetro e envia dados ao Firebase em segundo plano -->
        <service
            android:name=".MonitoramentoService"
            android:foregroundServiceType="health"
            android:exported="false" />

    </application>

</manifest>
